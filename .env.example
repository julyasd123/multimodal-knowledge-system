# 环境变量配置示例

# ==================== 基础配置 ====================
# 应用环境 (development/production/testing)
APP_ENV=development

# 应用调试模式 (True/False)
APP_DEBUG=True

# 应用密钥 (生产环境请修改为随机字符串)
APP_SECRET_KEY=your-secret-key-here

# ==================== 数据库配置 ====================
# PostgreSQL配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=knowledge_db
POSTGRES_USER=knowledge_user
POSTGRES_PASSWORD=knowledge_password

# Neo4j配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=knowledge_password

# Milvus配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_vectors

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== 大模型配置 ====================
# 小米MIMO API配置
MIMO_API_KEY=your-mimo-api-key-here
MIMO_API_BASE=https://api.mimo.xiaomi.com/v1
MIMO_MODEL=miimo-large
MIMO_EMBEDDING_MODEL=miimo-embedding-large

# OCR引擎配置
OCR_ENGINE=paddleocr
OCR_LANGUAGE=ch+en

# ==================== 文件存储配置 ====================
# 对象存储配置 (MinIO/S3/本地存储)
STORAGE_TYPE=local
STORAGE_BUCKET=knowledge-files
STORAGE_BASE_PATH=./data/storage

# MinIO配置 (如果使用MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==================== 消息队列配置 ====================
# RabbitMQ配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Celery配置
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ==================== 后端配置 ====================
# 后端服务端口
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 上传文件配置
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=[".pdf", ".docx", ".txt", ".jpg", ".jpeg", ".png"]

# ==================== 前端配置 ====================
# 前端服务端口
FRONTEND_PORT=3000

# API基础URL
REACT_APP_API_BASE_URL=http://localhost:8000/api/v1
REACT_APP_WS_BASE_URL=ws://localhost:8000/ws

# ==================== 日志配置 ====================
# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=./logs/app.log

# ==================== 监控配置 ====================
# Prometheus配置
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# Grafana配置
GRAFANA_ENABLED=False
GRAFANA_PORT=3001

# ==================== 安全配置 ====================
# JWT配置
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 速率限制
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ==================== 特性开关 ====================
# 是否启用注册功能
ENABLE_REGISTRATION=True

# 是否启用知识图谱可视化
ENABLE_KNOWLEDGE_GRAPH_VISUALIZATION=True

# 是否启用混合检索
ENABLE_HYBRID_RETRIEVAL=True

# 是否启用增量学习
ENABLE_INCREMENTAL_LEARNING=True

# ==================== Docker配置 ====================
# Docker Compose项目名
COMPOSE_PROJECT_NAME=multimodal-knowledge-system

# Docker网络名
DOCKER_NETWORK=multimodal-network

# ==================== 其他配置 ====================
# 时区
TIMEZONE=Asia/Shanghai

# 语言
LANGUAGE=zh-CN

# 注意事项：
# 1. 生产环境部署时，请务必修改所有默认的密码和密钥！
# 2. 不要将包含真实密钥的.env文件提交到Git仓库！
# 3. 生产环境建议使用环境变量或密钥管理服务来存储敏感信息。
# 4. 请参考文档完成完整配置：https://github.com/yourusername/multimodal-knowledge-system/docs/configuration.md